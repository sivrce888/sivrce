# Neon Postgres — pooled connection for the app runtime
DATABASE_URL=
# Neon Postgres — direct (non-pooled) connection, used by Prisma migrations
DIRECT_URL=

# Auth.js v5 — generate with: openssl rand -base64 32
AUTH_SECRET=
# Canonical site URL (required in prod / Vercel). Example: https://sivrce.ge
AUTH_URL=
# Google OAuth — create at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: {AUTH_URL}/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
# Comma-separated staff emails auto-promoted to admin on sign-in
ADMIN_EMAILS=giotskr@gmail.com

# Maps — MapLibre style (default: OpenFreeMap dark, no key). Override for MapTiler/Google.
# NEXT_PUBLIC_MAP_STYLE_URL=https://tiles.openfreemap.org/styles/dark
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=  # Places / Embed adapter (SIVRCE_TECH_STACK_DECISION §10a)

# ── Analytics & Monitoring ──────────────────────────────────────────

# PostHog (EU cloud) — product analytics + session replay
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# Sentry — error monitoring + Web Vitals
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# ── Email (Resend) ──────────────────────────────────────────────────

RESEND_API_KEY=

# ── AI (Gemini via Vercel AI SDK) ───────────────────────────────────

GOOGLE_GENERATIVE_AI_API_KEY=

# ── Search (Meilisearch) ────────────────────────────────────────────

MEILISEARCH_HOST=
MEILISEARCH_API_KEY=

# ── Storage (Cloudflare R2) ─────────────────────────────────────────
# Enable R2 in Cloudflare Dashboard first, create bucket + API token,
# then set keys. Public media host: https://cdn.sivrce.ge (images.sivrce.ge alias).
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=sivrce-media
R2_PUBLIC_URL=https://cdn.sivrce.ge

# ── Host map (Cloudflare DNS → Vercel, except mail) ─────────────────
# sivrce.ge / www → app (www→apex 308)
# admin.sivrce.ge → /admin rewrite
# api.sivrce.ge → /api rewrite
# cdn.sivrce.ge / images.sivrce.ge → static assets only (CF proxied)
# app.sivrce.ge / analytics.sivrce.ge → 308 → apex
# mail: MX on apex (namespace.ge) + Resend send.sivrce.ge

# ── Payments (TBC / BOG) ────────────────────────────────────────────

# TBC E-Commerce
TBC_MERCHANT_ID=
TBC_API_KEY=
TBC_API_SECRET=
TBC_CALLBACK_URL=
# BOG iPay (failover)
BOG_MERCHANT_ID=
BOG_API_KEY=
BOG_API_SECRET=
BOG_CALLBACK_URL=
# Payment provider selection: "tbc" | "bog" | "mock"
PAYMENT_PROVIDER=tbc

# ── SMS (Twilio Verify) ─────────────────────────────────────────────

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=
