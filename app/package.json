{
  "name": "sivrce",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "prebuild": "node scripts/og-derivatives.mjs || echo 'og-derivatives skipped'",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "check:map": "npx --yes tsx src/lib/map/buildings.check.ts",
    "check:attribution": "npx --yes tsx src/lib/map/attribution.check.ts",
    "check:geocode": "npx --yes tsx src/lib/map/geocode.check.ts",
    "check:search": "npx --yes tsx src/lib/search.check.ts",
    "check:seo-title": "npx --yes tsx src/lib/seo-title.check.ts",
    "check:seo-hub": "npx --yes tsx src/lib/seo-hub.check.ts",
    "sync:korter": "npx --yes tsx scripts/import-korter.ts",
    "postinstall": "prisma generate",
    "mobile:sync": "npx cap sync",
    "mobile:ios": "npx cap sync ios && npx cap open ios",
    "mobile:android": "npx cap sync android && npx cap open android",
    "mobile:dev": "NEXT_PUBLIC_CAPACITOR=true next dev -p 3000",
    "mobile:build": "next build && npx cap sync"
  },
  "dependencies": {
    "@ai-sdk/google": "^4.0.18",
    "@auth/prisma-adapter": "^2.11.2",
    "@aws-sdk/client-s3": "^3.1089.0",
    "@aws-sdk/s3-request-presigner": "^3.1089.0",
    "@base-ui/react": "^1.6.0",
    "@capacitor/android": "^8.4.2",
    "@capacitor/cli": "^8.4.2",
    "@capacitor/core": "^8.4.2",
    "@capacitor/ios": "^8.4.2",
    "@capacitor/splash-screen": "^8.0.2",
    "@capacitor/status-bar": "^8.0.3",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@sentry/nextjs": "^10.66.0",
    "ai": "^7.0.31",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "framer-motion": "^12.42.2",
    "lucide-react": "^1.24.0",
    "maplibre-gl": "^5.24.0",
    "meilisearch": "^0.59.0",
    "next": "16.2.10",
    "next-auth": "^5.0.0-beta.31",
    "next-themes": "^0.4.6",
    "pg": "^8.22.0",
    "posthog-js": "^1.404.0",
    "prisma": "^7.8.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.17.2",
    "shadcn": "^4.13.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "playwright": "^1.61.1",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5"
  }
}
